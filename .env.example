# ===== 伊伊的书房 — 环境变量模板 =====
# 复制此文件为 .env.local 并填入真实值

# 服务端口（默认 3000）
PORT=3000

# Supabase 项目地址（从 Supabase Dashboard > Settings > API 获取）
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名公钥（anon/public key，同上页面获取）
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# DeepSeek API Key（用于 AI 读书发现卡分析，从 platform.deepseek.com 获取）
VITE_DEEPSEEK_KEY=sk-your-deepseek-key
