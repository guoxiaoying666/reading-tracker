{
  "functions": {
    "api/analyze.mjs": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/classify.mjs": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/lookup.mjs": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
